# Chave da API Google (Gemini) - obter em https://aistudio.google.com/app/apikey
# Copie para .env.local e preencha com sua chave
GOOGLE_AI_API_KEY=

# Opcional: pasta para users.json, projects.json e tasks.json (padrão: ./data em dev;
# em Vercel/Lambda o app usa /tmp/docflow-data automaticamente).
# DOCFLOW_DATA_DIR=
