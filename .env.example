# OpenRouter (prioritário se preenchido) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Opcional: OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Google Gemini — usado se OPENROUTER_API_KEY estiver vazio (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=

# Opcional: pasta para users.json, projects.json e tasks.json (padrão: ./data em dev;
# em Vercel/Lambda o app usa /tmp/docflow-data automaticamente).
# DOCFLOW_DATA_DIR=
